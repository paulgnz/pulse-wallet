<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      No keychain-access-groups: a single standalone app uses its own default
      keychain group (bound to the stable team-signed app identifier), so keys
      persist across rebuilds without the fragile $(AppIdentifierPrefix) entitlement.
      Secure Enclave + Keychain + network all work without extra entitlements here.
    -->
</dict>
</plist>
