<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Required for Touch ID / biometric Keychain items (data-protection keychain).
      $(AppIdentifierPrefix) resolves from DEVELOPMENT_TEAM (locked in Signing.xcconfig),
      so the group is stable across rebuilds and keys persist.
    -->
    <key>keychain-access-groups</key>
    <array>
        <string>$(AppIdentifierPrefix)dev.pulsevm.wallet</string>
    </array>
</dict>
</plist>
